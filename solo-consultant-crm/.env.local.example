# ==============================================================================
# Solo Consultant CRM - Local Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local
#
# NEVER commit .env.local to version control. It is already in .gitignore.
# ==============================================================================

# --- Supabase ---
# Get these from your Supabase project: Settings > API
# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key - safe to expose in the browser. Used for client-side queries
# that go through Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Service role key - has FULL access, bypasses RLS. NEVER expose in client code.
# Used only in server actions and API routes.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# --- Resend (Email Service) ---
# Sign up at https://resend.com and create an API key.
# For development, you can use the free tier with resend.dev test domain.
# For production, add and verify your own sending domain in the Resend dashboard.
RESEND_API_KEY=re_your_api_key_here

# --- Application ---
# The public URL of your application.
# - Development: http://localhost:3000
# - Production: https://your-domain.com (or your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
